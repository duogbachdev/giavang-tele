# Telegram Bot
TELEGRAM_BOT_TOKEN=your_bot_token_here
TELEGRAM_CHAT_ID=your_chat_id_here

# Scan interval (milliseconds) - mac dinh 5 phut
SCAN_INTERVAL_MS=300000

# Chi gui thong bao khi gia thay doi (true/false)
NOTIFY_ON_CHANGE_ONLY=true

# Gui bao cao dinh ky moi N lan quet (0 = tat)
PERIODIC_REPORT_EVERY=12

# Cac nguon can quet (comma-separated): sjc,doji,pnj,btmc
SOURCES=sjc,doji,pnj,btmc

# Port cho health check (Render yeu cau)
PORT=3000